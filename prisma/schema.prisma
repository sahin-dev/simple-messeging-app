// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  avatar String?
  fcm_token String?

  email      String @unique
  name       String?
  licence_id String?
  nick_name  String @unique
  password   String
  is_more_options_accepted   Boolean  @default(false)
  designation String?
  is_blocked  Boolean  @default(false)
  is_deleted  Boolean  @default(false)
  email_verified Boolean @default(false)
  account_type AccountType @default(FREE)
  qr_code String?

  otp                    String?
  otp_expires            DateTime?
  otp_verification_token String?

  role UserRole @default(USER)

  chatRooms_user1 ChatRoom[]  @relation("user1")
  chatRooms_user2 ChatRoom[]  @relation("user2")
  blockLists      BlockList[] @relation("user")
  blockListsBy    BlockList[] @relation("blocked_user")
  sentMessages     Chat[] @relation("sender")
  receivedMessages Chat[] @relation("receiver")

  groupChatRooms GroupChatRoomMember[]
  groupChats     GroupChat[] @relation("sender")
  userRatingsGiven UserRating[] @relation("rater")
  userRatingsReceived UserRating[] @relation("ratee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ChatRoom {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  is_deleted Boolean @default(false)
  user1_id String @db.ObjectId
  user2_id String @db.ObjectId

  user1 User @relation("user1", fields: [user1_id], references: [id], onDelete: Cascade)
  user2 User @relation("user2", fields: [user2_id], references: [id], onDelete: Cascade)

  chats Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1_id, user2_id])
  @@map("chat_rooms")
}

model GroupChatRoom {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  image String?
  is_deleted Boolean @default(false)
  group_members_count Int @default(0)
  members GroupChatRoomMember[]

  chats GroupChat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("group_chat_rooms")
}

model GroupChatRoomMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  groupChatRoom_id String @db.ObjectId
  user_id String @db.ObjectId
  last_read_message_id String? @db.ObjectId
  group_role GroupRole @default(GROUP_MEMBER)

  groupChatRoom GroupChatRoom @relation(fields: [groupChatRoom_id], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupChatRoom_id, user_id])
  @@map("group_chat_room_members")
}

model GroupChat {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  groupChatRoom_id String @db.ObjectId
  sender_id String @db.ObjectId
  message String
  type MessageType @default(TEXT)

  groupChatRoom GroupChatRoom @relation(fields: [groupChatRoom_id], references: [id], onDelete: Cascade)
  sender User @relation(fields: [sender_id], references: [id], onDelete: Cascade, name: "sender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("group_chats")
}

model Chat {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  chatRoom_id  String      @db.ObjectId
  sender_id    String      @db.ObjectId
  receiver_id  String      @db.ObjectId
  message      String
  type         MessageType @default(TEXT)
  is_read      Boolean     @default(false)
  is_delivered Boolean     @default(false)

  chatRoom ChatRoom @relation(fields: [chatRoom_id], references: [id], onDelete: Cascade)
  sender   User     @relation("sender", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver User     @relation("receiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chats")
}

model PresetMessage {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  message String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("preset_messages")
}

model UsefullNumber {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title String
  phone String
  location location
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("useful_numbers")
}

type location {
  latitude Float
  longitude Float
}


model UserRating {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  rater_id String @db.ObjectId
  ratee_id String @db.ObjectId
  rating Int
  status RatingStatus @default(PENDING)

  rater User @relation("rater", fields: [rater_id], references: [id], onDelete: Cascade)
  ratee User @relation("ratee", fields: [ratee_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rater_id, ratee_id])
  @@map("user_ratings")
}



model BlockList {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user_id         String @db.ObjectId
  blocked_user_id String @db.ObjectId

  user         User @relation("user", fields: [user_id], references: [id], onDelete: Cascade)
  blocked_user User @relation("blocked_user", fields: [blocked_user_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user_id, blocked_user_id])
  @@map("block_list")
}

model SitePolicy {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  type PolicyType

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_policy")
}

enum MessageType {
  TEXT
}

model Point {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  description String?
  latitude Float
  longitude Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("points")
}

model BlackListedWord {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  word String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blacklisted_words")
}

enum JobType {
  SendWelcomeEmail
}

enum UserRole {
  USER
  ADMIN
}

enum PolicyType {
  PrivacyPolicy
  Terms
  More
}

enum GroupRole {
  GROUP_ADMIN
  GROUP_MEMBER
}

enum RatingStatus {
  PUBLISHED
  REJECTED
  PENDING
}

enum AccountType {
  FREE
  PREMIUM
}